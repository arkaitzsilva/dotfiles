{
  "label" : "shutdown",
  "action" : "systemctl poweroff",
  "text" : "Apagar",
  "keybind" : "s"
}
{
  "label" : "reboot",
  "action" : "systemctl reboot",
  "text" : "Reiniciar",
  "keybind" : "r"
}
{
  "label" : "logout",
  "action" : "loginctl terminate-user $USER",
  "text" : "Cerrar sesión",
  "keybind" : "e"
}
{
  "label" : "suspend",
  "action" : "systemctl suspend",
  "text" : "Suspender",
  "keybind" : "u"
}
{
  "label" : "lock",
  "action" : "hyprlock",
  "text" : "Bloquear",
  "keybind" : "l"
}
{
  "label" : "hibernate",
  "action" : "systemctl hibernate",
  "text" : "Hibernar",
  "keybind" : "h"
}
