[global]
frame_color = "#89b4fa"
separator_color= frame
width = 400
origin = top-right
offset = 10x10
padding = 10
text_icon_padding=10
horizontal_padding=10
frame_width = 2
gap_size = 4
corner_radius = 10

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
